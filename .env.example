# NotebookLM MCP Server — Environment Variables
# Copy to .env and customize as needed. All values below are defaults.

# === Browser Settings ===
HEADLESS=true
BROWSER_TIMEOUT=30000

# === Session Limits ===
MAX_SESSIONS=10
SESSION_TIMEOUT=900

# === Auto-Login (optional — for unattended use) ===
# WARNING: Store credentials securely. Never commit .env to git.
# AUTO_LOGIN_ENABLED=false
# LOGIN_EMAIL=
# LOGIN_PASSWORD=
# AUTO_LOGIN_TIMEOUT_MS=120000

# === Stealth Mode ===
# STEALTH_ENABLED=true
# STEALTH_RANDOM_DELAYS=true
# STEALTH_HUMAN_TYPING=true
# STEALTH_MOUSE_MOVEMENTS=true
# TYPING_WPM_MIN=160
# TYPING_WPM_MAX=240
# MIN_DELAY_MS=100
# MAX_DELAY_MS=400

# === NotebookLM Settings ===
# NOTEBOOK_URL=
# NOTEBOOK_DESCRIPTION=General knowledge base
# NOTEBOOK_TOPICS=General topics
# NOTEBOOK_CONTENT_TYPES=documentation,examples
# NOTEBOOK_USE_CASES=General research

# === Tool Profile ===
# NOTEBOOKLM_PROFILE=standard
# NOTEBOOKLM_DISABLED_TOOLS=

# === Chrome Profile & Multi-Instance ===
# NOTEBOOK_CHROME_PROFILE_DIR=
# NOTEBOOK_PROFILE_STRATEGY=auto
# NOTEBOOK_CLONE_PROFILE=false
# NOTEBOOK_CLEANUP_ON_STARTUP=true
# NOTEBOOK_CLEANUP_ON_SHUTDOWN=true
# NOTEBOOK_INSTANCE_TTL_HOURS=72
# NOTEBOOK_INSTANCE_MAX_COUNT=20
