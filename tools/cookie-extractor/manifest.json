{
  "manifest_version": 3,
  "name": "NotebookLM Cookie Extractor",
  "version": "1.0",
  "description": "Extract Google/NotebookLM cookies for MCP sync",
  "permissions": ["cookies"],
  "host_permissions": ["*://*.google.com/*", "*://*.notebooklm.google.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Extract NLM Cookies"
  }
}
